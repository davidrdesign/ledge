# CartRover / Extensiv Integration Manager credentials
# Find these at: CartRover account → Merchants → API keys
CARTROVER_USER=your_api_user_here
CARTROVER_KEY=your_api_key_here

# QuickBooks Online credentials
# Create an app at: https://developer.intuit.com → My Apps → Create an app
# Set the redirect URI to: https://<your-api-gateway-url>/qbo/callback
QBO_CLIENT_ID=your_qbo_client_id
QBO_CLIENT_SECRET=your_qbo_client_secret
QBO_REDIRECT_URI=https://your-api-gateway-url/qbo/callback
QBO_SANDBOX=true

# URL of the Ledge app (used to redirect back after OAuth)
APP_URL=http://localhost:3456/inventory-app.html
